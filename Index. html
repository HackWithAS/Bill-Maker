      </div>
      <div class="table-wrap">
        <table id="material-table">
          <thead>
            <tr>
              <th>S.No.</th>
              <th style="min-width:200px">Description</th>
              <th>Qty</th>
              <th>Unit</th>
              <th>Rate (₹)</th>
