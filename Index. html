        </div>
        <div>
          <label>Bill To (Client Name)</label>
          <input type="text" id="m-client" placeholder="e.g. Delhi Public School">
        </div>
        <div class="form-full">
          <label>Client Address (optional)</label>
          <input type="text" id="m-address" placeholder="e.g. Sector 67A, Gurgaon, Haryana">
        </div>
        <div class="form-full">
          <label>Subject</label>
