// ─────────────────────────────────────────
// PREVIEW & PRINT
// ─────────────────────────────────────────
function previewBill(type) {
  const html = type === 'labour' ? buildLabourBillHTML() : buildMaterialBillHTML();
  document.getElementById('modal-body').innerHTML = `
    ${html}
    <div class="print-btn-bar">
      <button class="btn btn-outline" onclick="closeModal()">✕ Bandh Karo</button>
      <button class="btn btn-success" onclick="doPrint()">🖨 Print / Save PDF</button>
    </div>`;
  document.getElementById('modal').classList.add('open');
  window._currentPrintHTML = html;
}

function closeModal() {
  document.getElementById('modal').classList.remove('open');
}

function doPrint() {
  const w = window.open('', '_blank');
  w.document.write(`<!DOCTYPE html><html><head>
    <meta charset="UTF-8">
    <title>PS Construction Invoice</title>
    <style>
      body{margin:0;font-family:Inter,Arial,sans-serif;font-size:13px;}
      .bill-paper{padding:32px 40px;}
      .bill-company{text-align:center;border-bottom:2px solid #E05A00;padding-bottom:12px;margin-bottom:16px;}
      .bill-company-name{font-size:22px;font-weight:800;color:#E05A00;letter-spacing:1px;}
      .bill-company-sub{font-size:12px;color:#666;}
      .bill-meta{display:flex;justify-content:space-between;margin-bottom:18px;font-size:12px;}
      .bill-to{background:#FFF4EE;border-left:3px solid #E05A00;padding:10px 14px;margin-bottom:18px;}
      .bill-to-name{font-weight:700;font-size:14px;}
      .bill-table{width:100%;border-collapse:collapse;margin-bottom:18px;font-size:12px;}
      .bill-table th{background:#1A1208;color:white;padding:8px 10px;text-align:left;font-size:11px;}
      .bill-table td{padding:7px 10px;border-bottom:1px solid #EEE;}
      .bill-table tr:nth-child(even) td{background:#FAFAFA;}
      .bill-total-row td{background:#E05A00!important;color:white;font-weight:700;padding:10px;}
      .num{text-align:right;}
      .bill-footer{margin-top:24px;border-top:1px solid #EEE;padding-top:16px;display:flex;justify-content:flex-end;}
      .bill-sign-line{border-top:1px solid #999;width:160px;margin:30px auto 4px;}
      .bill-words{font-size:11px;color:#666;font-style:italic;margin-bottom:16px;}
      @media print{@page{margin:15mm}}
    </style></head><body>${window._currentPrintHTML}</body></html>`);
  w.document.close();
  w.focus();
  setTimeout(() => { w.print(); }, 500);
}

function printBill(type) {
  const html = type === 'labour' ? buildLabourBillHTML() : buildMaterialBillHTML();
  window._currentPrintHTML = html;
  doPrint();
}

