function buildLabourBillHTML() {
  const inv = document.getElementById('l-invoice').value || '—';
  const date = fmtDate(document.getElementById('l-date').value);
  const ra = document.getElementById('l-ra').value || '';
  const client = document.getElementById('l-client').value || '—';
  const address = document.getElementById('l-address').value || '';
  const subject = document.getElementById('l-subject').value || '';
  const notes = document.getElementById('l-notes').value || '';

  let rows = '';
  let total = 0;
  lRows.forEach((id, i) => {
    const desc = document.getElementById('ld-'+id)?.value || '';
    const nos  = parseFloat(document.getElementById('ln-'+id)?.value) || 0;
    const len  = parseFloat(document.getElementById('ll-'+id)?.value) || 0;
    const ht   = parseFloat(document.getElementById('lh-'+id)?.value) || 0;
    const rate = parseFloat(document.getElementById('lr-'+id)?.value) || 0;
    const tot  = nos * len * ht;
    const amt  = tot * rate;
    total += amt;
    rows += `<tr>
      <td>${i+1}</td>
      <td>${desc}</td>
      <td class="num">${nos||''}</td>
      <td class="num">${len||''}</td>
      <td class="num">${ht||''}</td>
      <td class="num">${tot>0?fmtNum(tot):''}</td>
      <td class="num">${rate?'₹'+rate:''}</td>
      <td class="num"><strong>₹${fmtNum(amt)}</strong></td>
    </tr>`;
  });

  return `
  <div class="bill-paper">
    <div class="bill-company">
      <div class="bill-company-name">PS CONSTRUCTION</div>
      <div class="bill-company-sub">Mob: 8287528881 &nbsp;|&nbsp; ${ra}</div>
    </div>
    <div class="bill-meta">
      <div><strong>Invoice No.:</strong> ${inv}</div>
      <div class="bill-meta-right"><strong>Date:</strong> ${date}</div>
    </div>
    <div class="bill-to">
      <div style="font-size:11px;color:#888;margin-bottom:3px">BILL TO</div>
      <div class="bill-to-name">${client}</div>
      ${address ? `<div style="font-size:12px;color:#555">${address}</div>` : ''}
      ${subject ? `<div style="font-size:12px;color:#666;margin-top:4px"><em>${subject}</em></div>` : ''}
    </div>
    <table class="bill-table">
      <thead>
        <tr>
          <th>Sr.</th><th>Description</th><th class="num">Nos</th>
          <th class="num">Length</th><th class="num">Height</th>
          <th class="num">Total</th><th class="num">Rate</th><th class="num">Amount</th>
        </tr>
      </thead>
      <tbody>${rows}</tbody>
      <tfoot>
        <tr class="bill-total-row">
          <td colspan="7" style="text-align:right">KULL PAYABLE AMOUNT</td>
          <td class="num">₹${fmtNum(total)}</td>
        </tr>
      </tfoot>
    </table>
    <div class="bill-words">(${numWords(total)})</div>
    ${notes ? `<div style="font-size:11px;color:#555;border:1px dashed #DDD;padding:10px;border-radius:6px;margin-bottom:16px"><strong>Additional Notes:</strong><br>${notes}</div>` : ''}
    <div class="bill-footer">
      <div class="bill-sign">
        <div class="bill-sign-line"></div>
        <div style="font-size:12px;font-weight:700">For PS Construction</div>
        <div style="font-size:11px;color:#666">Authorized Signatory</div>
      </div>
    </div>
  </div>`;
}

