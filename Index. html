<!-- ── Preview Modal ── -->
<div class="modal-overlay" id="modal">
  <div class="modal">
    <div class="modal-header">
      <span style="font-weight:700">Bill Preview</span>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body" id="modal-body"></div>
  </div>
</div>

<script>
// ── Utilities ──
function today() {
  return new Date().toISOString().split('T')[0];
}
function fmtDate(d) {
  if (!d) return '';
  const [y, m, day] = d.split('-');
  return `${day}-${m}-${y}`;
}
function fmtNum(n) {
  return new Intl.NumberFormat('en-IN').format(Math.round(n));
}
function numWords(n) {
  if (n === 0) return 'Zero Only';
  const a = ['','One','Two','Three','Four','Five','Six','Seven','Eight','Nine',
    'Ten','Eleven','Twelve','Thirteen','Fourteen','Fifteen','Sixteen','Seventeen','Eighteen','Nineteen'];
  const b = ['','','Twenty','Thirty','Forty','Fifty','Sixty','Seventy','Eighty','Ninety'];
  function words(num) {
    if (num < 20) return a[num];
    if (num < 100) return b[Math.floor(num/10)] + (num%10 ? ' '+a[num%10] : '');
    if (num < 1000) return a[Math.floor(num/100)] + ' Hundred' + (num%100 ? ' '+words(num%100) : '');
    if (num < 100000) return words(Math.floor(num/1000)) + ' Thousand' + (num%1000 ? ' '+words(num%1000) : '');
    if (num < 10000000) return words(Math.floor(num/100000)) + ' Lakh' + (num%100000 ? ' '+words(num%100000) : '');
    return words(Math.floor(num/10000000)) + ' Crore' + (num%10000000 ? ' '+words(num%10000000) : '');
  }
  return words(Math.round(n)) + ' Only';
}

// ── Tab switch ──
function switchTab(tab) {
  document.getElementById('form-labour').style.display = tab === 'labour' ? '' : 'none';
  document.getElementById('form-material').style.display = tab === 'material' ? '' : 'none';
  document.getElementById('tab-labour').classList.toggle('active', tab === 'labour');
  document.getElementById('tab-material').classList.toggle('active', tab === 'material');
}

// ─────────────────────────────────────────
// LABOUR BILL
// ─────────────────────────────────────────
let lRows = [];
let lCounter = 0;

function addLabourRow(desc='', nos='', len='', ht='', rate='') {
  lCounter++;
  const id = lCounter;
  lRows.push(id);
  const tbody = document.getElementById('labour-tbody');
  const tr = document.createElement('tr');
  tr.id = 'lr-' + id;
  tr.innerHTML = `
    <td style="text-align:center;color:#999;font-size:12px" id="lnum-${id}">${lRows.length}</td>
    <td><input type="text" id="ld-${id}" value="${desc}" placeholder="Description likho..." onchange="calcLabourRow(${id})"></td>
    <td><input type="number" id="ln-${id}" value="${nos}" placeholder="0" style="width:60px;text-align:right" oninput="calcLabourRow(${id})"></td>
    <td><input type="number" id="ll-${id}" value="${len}" placeholder="0" style="width:70px;text-align:right" step="0.01" oninput="calcLabourRow(${id})"></td>
    <td><input type="number" id="lh-${id}" value="${ht}" placeholder="0" style="width:70px;text-align:right" step="0.01" oninput="calcLabourRow(${id})"></td>
    <td id="ltot-${id}" style="text-align:right;font-weight:600;color:#555">—</td>
    <td><input type="number" id="lr-${id}" value="${rate}" placeholder="47" style="width:70px;text-align:right" oninput="calcLabourRow(${id})"></td>
    <td id="lamt-${id}" style="text-align:right;font-weight:700;color:#E05A00">—</td>
    <td><button class="del-btn" onclick="delLabourRow(${id})">×</button></td>
  `;
  tbody.appendChild(tr);
  calcLabourRow(id);
}

function calcLabourRow(id) {
  const nos = parseFloat(document.getElementById('ln-'+id)?.value) || 0;
  const len = parseFloat(document.getElementById('ll-'+id)?.value) || 0;
  const ht  = parseFloat(document.getElementById('lh-'+id)?.value) || 0;
  const rate= parseFloat(document.getElementById('lr-'+id)?.value) || 0;
  const tot = nos * len * ht;
  const amt = tot * rate;
  document.getElementById('ltot-'+id).textContent = tot > 0 ? fmtNum(tot) : '—';
  document.getElementById('lamt-'+id).textContent = amt > 0 ? '₹'+fmtNum(amt) : '—';
  updateLabourTotal();
}

function delLabourRow(id) {
  document.getElementById('lr-'+id).remove();
  lRows = lRows.filter(r => r !== id);
  renumberLabour();
  updateLabourTotal();
}

function renumberLabour() {
  lRows.forEach((id, i) => {
    const el = document.getElementById('lnum-'+id);
    if (el) el.textContent = i + 1;
  });
}

function updateLabourTotal() {
  let total = 0;
  lRows.forEach(id => {
    const nos = parseFloat(document.getElementById('ln-'+id)?.value) || 0;
    const len = parseFloat(document.getElementById('ll-'+id)?.value) || 0;
    const ht  = parseFloat(document.getElementById('lh-'+id)?.value) || 0;
    const rate= parseFloat(document.getElementById('lr-'+id)?.value) || 0;
    total += nos * len * ht * rate;
  });
  document.getElementById('l-total-display').textContent = '₹' + fmtNum(total);
  document.getElementById('l-words-display').textContent = numWords(total);
  document.getElementById('l-item-count').textContent = lRows.length;
}

// ─────────────────────────────────────────
// MATERIAL BILL
// ─────────────────────────────────────────
let mRows = [];
let mCounter = 0;

function addMaterialRow(desc='', qty='', unit='pcs', rate='') {
  mCounter++;
  const id = mCounter;
  mRows.push(id);
  const tbody = document.getElementById('material-tbody');
  const tr = document.createElement('tr');
  tr.id = 'mr-' + id;
  tr.innerHTML = `
    <td style="text-align:center;color:#999;font-size:12px" id="mnum-${id}">${mRows.length}</td>
    <td><input type="text" id="md-${id}" value="${desc}" placeholder="Item ka naam..." oninput="calcMaterialRow(${id})"></td>
    <td><input type="text" id="mq-${id}" value="${qty}" placeholder="20 pcs" style="width:80px" oninput="calcMaterialRow(${id})"></td>
    <td>
      <select id="mu-${id}" onchange="calcMaterialRow(${id})" style="width:80px">
        <option value="pcs" ${unit==='pcs'?'selected':''}>pcs</option>
        <option value="sq.ft." ${unit==='sq.ft.'?'selected':''}>sq.ft.</option>
        <option value="m²" ${unit==='m²'?'selected':''}>m²</option>
        <option value="m" ${unit==='m'?'selected':''}>m</option>
        <option value="kg" ${unit==='kg'?'selected':''}>kg</option>
        <option value="ton" ${unit==='ton'?'selected':''}>ton</option>
        <option value="bag" ${unit==='bag'?'selected':''}>bag</option>
        <option value="ltr" ${unit==='ltr'?'selected':''}>ltr</option>
        <option value="nos" ${unit==='nos'?'selected':''}>nos</option>
        <option value="month" ${unit==='month'?'selected':''}>month</option>
        <option value="—" ${unit==='—'?'selected':''}>—</option>
      </select>
    </td>
    <td><input type="number" id="mr-${id}" value="${rate}" placeholder="0" style="width:90px;text-align:right" oninput="calcMaterialRow(${id})"></td>
    <td id="mamt-${id}" style="text-align:right;font-weight:700;color:#E05A00">—</td>
    <td><button class="del-btn" onclick="delMaterialRow(${id})">×</button></td>
  `;
  tbody.appendChild(tr);
  calcMaterialRow(id);
}

function calcMaterialRow(id) {
  const qtyStr = document.getElementById('mq-'+id)?.value || '';
  const qty = parseFloat(qtyStr) || 0;
  const rate = parseFloat(document.getElementById('mr-'+id)?.value) || 0;
  const amt = qty * rate;
  document.getElementById('mamt-'+id).textContent = amt > 0 ? '₹'+fmtNum(amt) : '—';
  updateMaterialTotal();
}

function delMaterialRow(id) {
  document.getElementById('mr-'+id).remove();
  mRows = mRows.filter(r => r !== id);
  renumberMaterial();
  updateMaterialTotal();
}

function renumberMaterial() {
  mRows.forEach((id, i) => {
    const el = document.getElementById('mnum-'+id);
    if (el) el.textContent = i + 1;
  });
}

function updateMaterialTotal() {
  let total = 0;
  mRows.forEach(id => {
    const qty = parseFloat(document.getElementById('mq-'+id)?.value) || 0;
    const rate= parseFloat(document.getElementById('mr-'+id)?.value) || 0;
    total += qty * rate;
  });
  document.getElementById('m-total-display').textContent = '₹' + fmtNum(total);
  document.getElementById('m-words-display').textContent = numWords(total);
  document.getElementById('m-item-count').textContent = mRows.length;
}

// ─────────────────────────────────────────
// CLEAR
// ─────────────────────────────────────────
function clearForm(type) {
  if (!confirm('Sab data clear ho jayega. Sure ho?')) return;
  if (type === 'labour') {
    document.getElementById('labour-tbody').innerHTML = '';
    lRows = []; lCounter = 0;
    ['l-invoice','l-date','l-ra','l-client','l-address','l-subject','l-notes']
      .forEach(id => { const el=document.getElementById(id); if(el) el.value=''; });
    updateLabourTotal();
  } else {
    document.getElementById('material-tbody').innerHTML = '';
    mRows = []; mCounter = 0;
    ['m-invoice','m-date','m-client','m-address','m-subject','m-notes']
      .forEach(id => { const el=document.getElementById(id); if(el) el.value=''; });
    updateMaterialTotal();
  }
}

