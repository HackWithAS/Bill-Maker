<!DOCTYPE html>
<html lang="hi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PS Construction – Bill Maker</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Noto+Sans+Devanagari:wght@400;600&display=swap');

  :root {
    --orange: #E05A00;
    --orange-light: #FF7A2F;
    --orange-pale: #FFF4EE;
    --dark: #1A1208;
    --mid: #4A3728;
    --muted: #9B8070;
    --border: #E8D8CC;
    --bg: #FAF7F4;
    --white: #FFFFFF;
    --success: #2A7C4F;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Inter', 'Noto Sans Devanagari', sans-serif;
    background: var(--bg);
    color: var(--dark);
    min-height: 100vh;
  }

  /* ── Header ── */
  header {
    background: var(--dark);
    padding: 0 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .logo {
    display: flex; align-items: center; gap: 10px;
    color: var(--white); font-size: 18px; font-weight: 700; letter-spacing: -.3px;
  }
  .logo-badge {
    background: var(--orange); color: white;
    font-size: 11px; font-weight: 700;
    padding: 3px 8px; border-radius: 4px;
    letter-spacing: .5px;
  }
  .header-sub { color: var(--muted); font-size: 13px; }

  /* ── Tab bar ── */
  .tabs {
    background: var(--white);
    border-bottom: 1px solid var(--border);
    display: flex; padding: 0 32px; gap: 0;
  }
  .tab-btn {
    padding: 14px 24px; border: none; background: none;
    font-size: 14px; font-weight: 500; color: var(--muted);
    cursor: pointer; border-bottom: 3px solid transparent;
    transition: all .2s; display: flex; align-items: center; gap: 7px;
  }
  .tab-btn.active { color: var(--orange); border-color: var(--orange); }
  .tab-btn:hover { color: var(--dark); }

  /* ── Main layout ── */
  .container { max-width: 960px; margin: 32px auto; padding: 0 24px 80px; }

  /* ── Form card ── */
  .card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px;
    margin-bottom: 20px;
  }
  .card-title {
    font-size: 13px; font-weight: 600; color: var(--muted);
    text-transform: uppercase; letter-spacing: .8px;
    margin-bottom: 20px; padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 8px;
  }
  .card-title svg { color: var(--orange); }

  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .form-grid.three { grid-template-columns: 1fr 1fr 1fr; }
  .form-full { grid-column: 1/-1; }

  label { display: block; font-size: 12px; font-weight: 600; color: var(--mid); margin-bottom: 6px; }
  input, select, textarea {
    width: 100%; padding: 10px 14px;
    border: 1.5px solid var(--border); border-radius: 8px;
    font-size: 14px; font-family: inherit; color: var(--dark);
    background: var(--white); outline: none;
    transition: border-color .2s;
  }
  input:focus, select:focus, textarea:focus { border-color: var(--orange); }
  textarea { resize: vertical; min-height: 60px; }

  /* ── Items table ── */
  .items-header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 16px;
  }
  .items-title { font-size: 13px; font-weight: 700; color: var(--dark); }

  .table-wrap { overflow-x: auto; border-radius: 8px; border: 1px solid var(--border); }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th {
    background: var(--orange-pale); color: var(--orange);
    padding: 10px 12px; text-align: left;
    font-size: 11px; font-weight: 700; letter-spacing: .5px;
    border-bottom: 1px solid var(--border); white-space: nowrap;
  }
  td { padding: 8px 10px; border-bottom: 1px solid #F2EBE6; vertical-align: middle; }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: var(--orange-pale); }

  td input {
    padding: 7px 10px; border-radius: 6px; font-size: 13px;
    border: 1.5px solid transparent; background: transparent;
  }
  td input:focus { background: white; border-color: var(--orange); }

  .del-btn {
    background: none; border: none; cursor: pointer;
    color: #D0A090; font-size: 18px; padding: 4px;
    border-radius: 4px; transition: color .2s;
  }
  .del-btn:hover { color: #C0392B; }

  /* ── Buttons ── */
  .btn {
    padding: 10px 20px; border-radius: 8px; font-size: 14px;
    font-weight: 600; cursor: pointer; border: none;
    font-family: inherit; transition: all .2s;
    display: inline-flex; align-items: center; gap: 7px;
  }
  .btn-primary { background: var(--orange); color: white; }
  .btn-primary:hover { background: var(--orange-light); }
  .btn-outline {
    background: none; border: 1.5px solid var(--border);
    color: var(--mid);
  }
  .btn-outline:hover { border-color: var(--orange); color: var(--orange); }
  .btn-success { background: var(--success); color: white; }
  .btn-success:hover { opacity: .9; }

  .actions {
    display: flex; gap: 12px; justify-content: flex-end;
    margin-top: 24px; flex-wrap: wrap;
  }

  /* ── Summary strip ── */
  .summary {
    background: var(--dark); color: white;
    border-radius: 10px; padding: 20px 28px;
    display: flex; justify-content: space-between; align-items: center;
    margin-top: 20px; flex-wrap: wrap; gap: 16px;
  }
  .summary-label { font-size: 13px; color: var(--muted); margin-bottom: 4px; }
  .summary-value { font-size: 22px; font-weight: 700; }
  .summary-words { font-size: 12px; color: var(--muted); margin-top: 3px; }
  .summary-right { text-align: right; }

  /* ── Print / Preview ── */
  #preview-area { display: none; }

  @media (max-width: 640px) {
    .form-grid, .form-grid.three { grid-template-columns: 1fr; }
    header { padding: 0 16px; }
    .tabs { padding: 0 12px; }
    .tab-btn { padding: 12px 14px; font-size: 13px; }
    .container { margin: 16px auto; padding: 0 12px 60px; }
    .card { padding: 18px; }
  }

  /* ── Print styles ── */
  @media print {
    body { background: white; }
    header, .tabs, .actions, .no-print { display: none !important; }
    .container { margin: 0; padding: 0; max-width: 100%; }
    .card { border: none; box-shadow: none; }
    .print-bill { display: block !important; }
  }

  /* ── Bill Preview Modal ── */
  .modal-overlay {
    display: none; position: fixed; inset: 0;
    background: rgba(0,0,0,.5); z-index: 200;
    justify-content: center; align-items: flex-start;
    padding: 20px; overflow-y: auto;
  }
  .modal-overlay.open { display: flex; }
  .modal {
    background: white; width: 100%; max-width: 800px;
    border-radius: 12px; overflow: hidden;
    margin: auto;
  }
  .modal-header {
    background: var(--dark); color: white;
    padding: 16px 24px; display: flex;
    justify-content: space-between; align-items: center;
  }
  .modal-close {
    background: none; border: none; color: white;
    font-size: 22px; cursor: pointer;
  }
  .modal-body { padding: 0; }

  /* ── Bill printout ── */
  .bill-paper {
    background: white; padding: 32px 40px;
    font-family: 'Inter', sans-serif; font-size: 13px;
    color: #111; line-height: 1.5;
  }
  .bill-company {
    text-align: center; border-bottom: 2px solid #E05A00;
    padding-bottom: 12px; margin-bottom: 16px;
  }
  .bill-company-name {
    font-size: 22px; font-weight: 800; color: #E05A00; letter-spacing: 1px;
  }
  .bill-company-sub { font-size: 12px; color: #666; }
  .bill-meta {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 8px; margin-bottom: 18px; font-size: 12px;
  }
  .bill-meta-right { text-align: right; }
  .bill-meta strong { color: #333; }
  .bill-to { background: #FFF4EE; border-left: 3px solid #E05A00; padding: 10px 14px; margin-bottom: 18px; border-radius: 0 6px 6px 0; }
  .bill-to-name { font-weight: 700; font-size: 14px; }

  .bill-table { width: 100%; border-collapse: collapse; margin-bottom: 18px; font-size: 12px; }
  .bill-table th {
    background: #1A1208; color: white; padding: 8px 10px;
    text-align: left; font-size: 11px;
  }
  .bill-table td { padding: 7px 10px; border-bottom: 1px solid #EEE; }
  .bill-table tr:nth-child(even) td { background: #FAFAFA; }
  .bill-table .num { text-align: right; }

  .bill-total-row { background: #E05A00 !important; }
  .bill-total-row td { color: white; font-weight: 700; padding: 10px; }

  .bill-footer { margin-top: 24px; border-top: 1px solid #EEE; padding-top: 16px; display: flex; justify-content: flex-end; }
  .bill-sign { text-align: center; }
  .bill-sign-line { border-top: 1px solid #999; width: 160px; margin: 30px auto 4px; }
  .bill-words { font-size: 11px; color: #666; font-style: italic; margin-bottom: 16px; }
  .print-btn-bar { padding: 16px 24px; display: flex; gap: 10px; justify-content: flex-end; background: #F5F5F5; border-top: 1px solid #EEE; }
</style>
</head>
<body>

<header>
  <div class="logo">
    <span>🏗️</span>
    <span>PS Construction</span>
    <span class="logo-badge">BILL MAKER</span>
  </div>
  <span class="header-sub">Mob: 8287528881</span>
</header>

<div class="tabs">
  <button class="tab-btn active" onclick="switchTab('labour')" id="tab-labour">
    <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6M8 13h8M8 17h5"/></svg>
