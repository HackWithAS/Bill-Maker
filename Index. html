  </div>

  <!-- ─────── MATERIAL BILL FORM ─────── -->
  <div id="form-material" style="display:none">
    <div class="card">
      <div class="card-title">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        Bill Details
      </div>
      <div class="form-grid three">
        <div>
          <label>Invoice No.</label>
          <input type="text" id="m-invoice" placeholder="e.g. 11">
        </div>
        <div>
          <label>Date</label>
